# ============================================
# PCI Prediction API - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (already in .gitignore)

# ============================================
# TabPFN Hugging Face Token (Optional)
# ============================================
# Required only if you want to use TabPFN model for few-shot learning
# Get your token from: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Server Configuration
# ============================================
PORT=3000
PYTHONUNBUFFERED=1

# ============================================
# Cloudflare 배포 설정 (선택사항)
# ============================================

# --- 방법 1: Cloudflare Zero Trust Tunnel (권장) ---
# Cloudflare Zero Trust 대시보드에서 터널 생성 후 토큰 입력
# https://one.dash.cloudflare.com/ → Networks → Tunnels → Create a tunnel
# CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoixxxxxxxxxxxxxxxxxxxxxxxx

# --- 방법 2: Cloudflare Pages (프론트엔드 전용 배포) ---
# Cloudflare API 토큰 (Pages:Edit 권한 필요)
# https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# 백엔드 서버 URL (Pages 배포 시 API 요청 대상)
# BACKEND_URL=https://your-backend-server.com
